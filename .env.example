# Pick one or more search providers. The server will use the first configured provider.
# Supported SEARCH_PROVIDER values: tavily, brave, bing, serpapi, wikipedia
SEARCH_PROVIDER=tavily
TAVILY_API_KEY=
BRAVE_API_KEY=
BING_API_KEY=
SERPAPI_API_KEY=

# Optional. When present, synthesis uses OpenAI; otherwise a local extractive synthesizer is used.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Optional server settings.
PORT=8787
